{
  "name": "lantern",
  "version": "1.0.0",
  "license": "GPL-3.0-or-later",
  "private": true,
  "main": "node_modules/expo/AppEntry.js",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "prebuild": "expo prebuild",
    "build:preview": "npx --yes eas-cli build --profile preview --platform all",
    "build:production": "npx --yes eas-cli build --profile production --platform all",
    "build:android:preview": "npx --yes eas-cli build --profile preview --platform android",
    "build:android:production": "npx --yes eas-cli build --profile production --platform android",
    "submit:android:production": "npx --yes eas-cli submit --profile production --platform android",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "lint": "eslint . && prettier --check .",
    "format": "eslint . --fix && prettier --write .",
    "check:knip": "knip",
    "check": "npm run typecheck && npm test -- --runInBand && npm run lint && npm run check:knip",
    "doctor": "npx --yes expo-doctor",
    "generate:fingerprints": "node scripts/generate-bluetooth-numbers.mjs && node scripts/generate-fastpair-models.mjs && node scripts/generate-ha-registry.mjs && node scripts/generate-oui.mjs && node scripts/generate-recog.mjs && node scripts/generate-sniffypedia.mjs && node scripts/generate-theengs.mjs && node scripts/generate-xiaomi-products.mjs"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/netinfo": "12.0.1",
    "@react-native-vector-icons/feather": "^13.1.2",
    "@react-native-vector-icons/material-design-icons": "^13.1.2",
    "@react-navigation/native": "^7.2.4",
    "@react-navigation/native-stack": "^7.15.1",
    "@tanstack/query-async-storage-persister": "^5.100.10",
    "@tanstack/react-query": "^5.100.10",
    "@tanstack/react-query-persist-client": "^5.100.10",
    "expo": "~57.0.7",
    "expo-constants": "~57.0.6",
    "expo-crypto": "~57.0.1",
    "expo-status-bar": "~57.0.1",
    "expo-system-ui": "~57.0.1",
    "javascript-time-ago": "^2.6.4",
    "nativewind": "^4.2.6",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.86.0",
    "react-native-ble-plx": "^3.5.1",
    "react-native-css-interop": "^0.2.6",
    "react-native-gesture-handler": "~2.32.0",
    "react-native-reanimated": "4.5.0",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-tcp-socket": "^6.4.1",
    "react-native-udp": "^4.1.7",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.10.0",
    "react-native-zeroconf": "^0.14.0",
    "react-time-ago": "^7.4.4"
  },
  "devDependencies": {
    "@babel/core": "^7.20.0",
    "@types/jest": "^29.5.14",
    "@types/react": "~19.2.10",
    "babel-preset-expo": "~57.0.0",
    "eslint": "^9.25.1",
    "eslint-config-expo": "~57.0.0",
    "globals": "^17.6.0",
    "jest": "^29.7.0",
    "jest-expo": "~57.0.2",
    "knip": "^6.16.1",
    "prettier": "^3.2.5",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "react-test-renderer": "^19.2.3",
    "tailwindcss": "^3.4.0",
    "typescript": "~6.0.3"
  },
  "overrides": {
    "uuid": "^11.1.1"
  },
  "expo": {
    "doctor": {
      "reactNativeDirectoryCheck": {
        "exclude": [
          "@react-native-vector-icons/feather",
          "@react-native-vector-icons/material-design-icons",
          "react-native-tcp-socket",
          "react-native-udp"
        ]
      }
    }
  }
}
